# Flow Procurement — environment variables
# Copy to `.env` and fill in secrets. NEVER commit .env to git.
# All names use FLOW_ prefix per app.config.Settings(env_prefix="FLOW_").

# ── Database (optional — falls back to local SQLite/in-memory) ──
# FLOW_TURSO_DATABASE_URL=libsql://your-db.turso.io
# FLOW_TURSO_AUTH_TOKEN=eyJ...

# ── AI Copilot ──
# Anthropic key — Haiku (routine) + Sonnet (reasoning) + Claude fallback
FLOW_LLM_API_KEY=sk-ant-...
FLOW_LLM_PROVIDER=claude                    # claude | gemini
# FLOW_LLM_MODEL=claude-haiku-4-5-20251001
# FLOW_LLM_HEAVY_MODEL=claude-sonnet-4-6
# FLOW_LLM_MAX_TOKENS=512
# FLOW_LLM_HEAVY_MAX_TOKENS=1024
# FLOW_LLM_TEMPERATURE=0.3

# Google Gemini — final fallback if Claude fails
FLOW_GEMINI_API_KEY=AIzaSy...
# FLOW_GEMINI_MODEL=gemini-2.0-flash

# ── Auth ──
FLOW_JWT_SECRET=change-me-to-a-random-secret
# FLOW_JWT_ACCESS_EXPIRE_MINUTES=480
# FLOW_JWT_REFRESH_EXPIRE_DAYS=30

# ── Marketplace (optional) ──
# FLOW_ALLEGRO_CLIENT_ID=
# FLOW_ALLEGRO_CLIENT_SECRET=
# FLOW_ALLEGRO_SANDBOX=false

# ── Solver defaults ──
# FLOW_DEFAULT_SOLVER_MODE=continuous
# FLOW_DEFAULT_MAX_VENDOR_SHARE=0.60
# FLOW_DEFAULT_MIN_ESG_SCORE=0.70
# FLOW_DEFAULT_MAX_PAYMENT_TERMS_DAYS=60
# FLOW_MONTE_CARLO_ITERATIONS=1000
# FLOW_SOLVER_TIME_LIMIT_SECONDS=60

# ── Document parsing ──
# Disable on dev machines without tesseract + poppler installed
# FLOW_PDF_OCR_ENABLED=true

# ── Production hardening ──
# Per-IP per-minute limit on /api/v1/* (0 = disabled)
FLOW_RATE_LIMIT_PER_MINUTE=120
# Comma-separated CORS origins
# FLOW_CORS_ORIGINS=https://flow-procurement.up.railway.app,http://localhost:8000
